# ─── API URLs ───────────────────────────────────────────────
# Dev: points directly at your local backend
VITE_API_URL=http://localhost:4000/api/v1

# Vite proxy target (must match PORT in backend/.env)
VITE_API_PROXY_TARGET=http://localhost:4000

# Prod: set this in your CI/CD or .env.production
# VITE_API_URL=https://your-production-api.com/api/v1
